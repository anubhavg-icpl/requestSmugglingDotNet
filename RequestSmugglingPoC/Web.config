<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <appSettings>
    <!-- Toggle the SmugglingDefenseModule on/off without recompiling.
         "true"  = hardened build (rejects ambiguous CL/TE, etc.)
         "false" = vulnerable build (for KBA demonstration only) -->
    <add key="Hardening.Enabled" value="true"/>
  </appSettings>

  <system.web>
    <compilation debug="true" targetFramework="4.0"/>
    <httpRuntime targetFramework="4.0" requestValidationMode="2.0" enableVersionHeader="false"/>
    <customErrors mode="Off"/>
    <pages validateRequest="false"/>

    <!-- Classic-pipeline registration (xsp4 / IIS classic mode / Cassini) -->
    <httpModules>
      <add name="SmugglingDefense" type="RequestSmugglingPoC.SmugglingDefenseModule"/>
    </httpModules>
    <httpHandlers>
      <add verb="*" path="api/echo.ashx"   type="RequestSmugglingPoC.EchoHandler"/>
      <add verb="*" path="api/login.ashx"  type="RequestSmugglingPoC.LoginHandler"/>
      <add verb="*" path="api/admin.ashx"  type="RequestSmugglingPoC.AdminHandler"/>
      <add verb="*" path="api/search.ashx" type="RequestSmugglingPoC.SearchHandler"/>
      <add verb="*" path="api/status.ashx" type="RequestSmugglingPoC.StatusHandler"/>
    </httpHandlers>
  </system.web>

  <system.webServer>
    <validation validateIntegratedModeConfiguration="false"/>
    <modules>
      <add name="SmugglingDefense" type="RequestSmugglingPoC.SmugglingDefenseModule" preCondition=""/>
    </modules>
    <handlers>
      <add name="EchoHandler"   verb="*" path="api/echo.ashx"   type="RequestSmugglingPoC.EchoHandler"/>
      <add name="LoginHandler"  verb="*" path="api/login.ashx"  type="RequestSmugglingPoC.LoginHandler"/>
      <add name="AdminHandler"  verb="*" path="api/admin.ashx"  type="RequestSmugglingPoC.AdminHandler"/>
      <add name="SearchHandler" verb="*" path="api/search.ashx" type="RequestSmugglingPoC.SearchHandler"/>
      <add name="StatusHandler" verb="*" path="api/status.ashx" type="RequestSmugglingPoC.StatusHandler"/>
    </handlers>
    <httpProtocol>
      <customHeaders>
        <remove name="X-Powered-By"/>
      </customHeaders>
    </httpProtocol>
  </system.webServer>
</configuration>
